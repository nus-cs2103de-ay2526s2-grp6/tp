@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR_4
skinparam classBackgroundColor MODEL_COLOR
skinparam nodesep 60
skinparam ranksep 50

package Model as ModelPackage <<Rectangle>> {
    Class "<<interface>>\nModel" as Model
    Class ModelManager
    Class ExpenseList
    Class "<<utility>>\nBalanceCalculator" as BalanceCalculator
    Class Expense
    Class Balance
    Class Group
    Class Person
    Class Participant
    Class Tag
    Class "ExpenseType\n<<enumeration>>" as ExpenseType
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

ModelManager .up.|> Model
ModelManager *-down-> "1" ExpenseList
ModelManager .right.> BalanceCalculator : uses

ExpenseList *-down-> "*" Expense

Expense *-up-> "1" ExpenseType
Expense *-left-> "1" Group : group >
Expense *-right-> "*" Tag : tags >
Expense *-down-> "*" Participant : participants >
Expense *-down-> "1" Person : payer >

Participant *-right-> "1" Person : person >

BalanceCalculator .down.> Expense : calculate(...)
BalanceCalculator .down.> Group
BalanceCalculator -down-> "*" Balance : creates

Balance *--> "1" Person : debtor >
Balance *--> "1" Person : creditor >

Model .down.> Expense
Model .down.> Balance

ExpenseList -[hidden]right- BalanceCalculator
@enduml