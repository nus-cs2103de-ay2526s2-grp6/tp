@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR_4
skinparam classBackgroundColor MODEL_COLOR
skinparam nodesep 60
skinparam ranksep 60

package Model as ModelPackage <<Rectangle>> {
    Class "<<interface>>\nModel" as Model
    Class ModelManager
    Class ExpenseList
    Class Expense
    Class Participant
    Class Group
    Class Person
    Class Tag
    Class Balance
    Class "<<utility>>\nBalanceCalculator" as BalanceCalculator
    Class "ExpenseType\n<<enumeration>>" as ExpenseType
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

ModelManager .up.|> Model
ModelManager *-left-> "1" ExpenseList
ModelManager ..> BalanceCalculator : uses

ExpenseList *-down-> "*" Expense

Expense *-down-> "1" Group : group >
Expense *-down-> "1" Person : payer >
Expense *-down-> "*" Participant : participants >
Expense *-down-> "*" Tag : tags >
Expense --> "1" ExpenseType

Participant *-down-> "1" Person : person >

Balance *-down-> "1" Person : debtor >
Balance *-down-> "1" Person : creditor >

Model .down.> Expense
Model .down.> Balance

BalanceCalculator ..> Expense : calculate(...)
BalanceCalculator ..> Group
BalanceCalculator -down-> "*" Balance : creates

Group -[hidden]right- Person
Person -[hidden]right- Tag
ExpenseList -[hidden]right- BalanceCalculator
@enduml
