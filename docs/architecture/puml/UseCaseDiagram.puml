@startuml

skinparam backgroundColor white
skinparam defaultFontName Arial
left to right direction

skinparam usecase {
    BackgroundColor #DDE8DC
    BorderColor #5A8A6A
    FontColor #1E293B
}

skinparam actor {
    BackgroundColor #DDE8DC
    BorderColor #5A8A6A
    FontColor #1E293B
}

skinparam rectangle {
    BackgroundColor #EFF6FF
    BorderColor #2563EB
    FontColor #1E293B
}

actor User as U
actor System as S

rectangle "Shared Expense Tracker" {
    usecase "Add Expense" as UC1
    usecase "Delete Expense" as UC2
    usecase "List All Expenses" as UC3
    usecase "Filter Expenses\n(by name, payer,\nparticipant or tag)" as UC4
    usecase "View Balance Summary" as UC5
    usecase "View Help" as UC6
    usecase "Auto-calculate Balances" as UC7
    usecase "Auto-save Data" as UC8
    usecase "Auto-load Data" as UC9
    usecase "Update Expense" as UC_UPDATE
}

U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5
U --> UC6
U --> UC_UPDATE

S --> UC7
S --> UC8
S --> UC9

UC1 .down.> UC7 : <<triggers>>
UC1 .down.> UC8 : <<triggers>>
UC2 .down.> UC7 : <<triggers>>
UC2 .down.> UC8 : <<triggers>>
UC_UPDATE .down.> UC7 : <<triggers>>
UC_UPDATE .down.> UC8 : <<triggers>>

@enduml
