@startuml

skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam rectangleFontSize 12

package "UI Layer" #DBEAFE {
    rectangle "MainWindow" #5B9BD5
    rectangle "GroupPanel" #5B9BD5
    rectangle "ExpensePanel" #5B9BD5
    rectangle "DebtPanel" #5B9BD5
}

package "Logic Layer" #EDE9FE {
    rectangle "ExpenseManager" #7C3AED
    rectangle "DebtCalculator" #7C3AED
}

package "Model Layer" #DCFCE7 {
    rectangle "Group" #15803D
    rectangle "Person" #15803D
    rectangle "Expense" #15803D
    rectangle "Debt" #15803D
}

package "Storage Layer" #FEF3C7 {
    rectangle "Storage" #B45309
}

"UI Layer" -down-> "Logic Layer" : calls
"Logic Layer" -down-> "Model Layer" : reads/updates
"Logic Layer" -down-> "Storage Layer" : saves/loads

@enduml
