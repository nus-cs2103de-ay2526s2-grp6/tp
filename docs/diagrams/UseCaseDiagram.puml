@startuml

skinparam backgroundColor white
skinparam defaultFontName Arial
left to right direction

skinparam usecase {
    BackgroundColor #DDE8DC
    BorderColor #5A8A6A
    FontColor #1E293B
}

skinparam actor {
    BackgroundColor #DDE8DC
    BorderColor #5A8A6A
    FontColor #1E293B
}

skinparam rectangle {
    BackgroundColor #EFF6FF
    BorderColor #2563EB
    FontColor #1E293B
}

actor User as U
actor System as S

rectangle "Shared Expense Tracker" {
    usecase "Create Group" as UC1
    usecase "Rename Group" as UC2
    usecase "Add Member" as UC3
    usecase "Add Expense" as UC4
    usecase "Edit Expense" as UC5
    usecase "Delete Expense\n(with confirmation)" as UC6
    usecase "View Expense List" as UC7
    usecase "Search Expenses" as UC8
    usecase "Choose Split Method" as UC9
    usecase "View Balances" as UC10
    usecase "Mark Debt as Settled" as UC11
    usecase "Auto-calculate Balances" as UC12
    usecase "Auto-save Data" as UC13
    usecase "Auto-load Data" as UC14
}

' User arrows
U --> UC1
U --> UC2
U --> UC3
U --> UC4
U --> UC5
U --> UC6
U --> UC7
U --> UC8
U --> UC9
U --> UC10
U --> UC11

' System arrows
S --> UC12
S --> UC13
S --> UC14

@enduml
