@startuml

skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam sequenceMessageAlign center
hide footbox

skinparam participant {
    BackgroundColor #DDE8DC
    BorderColor #5A8A6A
    FontColor #1E293B
}

skinparam arrow {
    Color #1E293B
    FontColor #1E293B
}

actor User

participant "ExpensePanel" as EP
participant "ExpenseManager" as EM
participant "DebtCalculator" as DC
participant "Storage" as ST

User -> EP : fill in expense form
User -> EP : click Add

EP -> EM : addExpense()

activate EM
EM -> EM : validate()
EM -> EM : new Expense()
EM -> EM : group.addExpense(expense)

EM -> DC : computeBalances()
activate DC
DC -> DC : update()
DC --> EM : return debts
deactivate DC

EM -> ST : saveData()
activate ST
ST --> EM : saved
deactivate ST

EM --> EP : refreshUI()
deactivate EM

EP --> User : updated expense list

@enduml
