<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      minHeight="0.0"
      style="-fx-background-color: #e8eef7;">

    <Label text="Group Balances"
           style="-fx-font-size: 16;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1a2a4a;">
        <padding>
            <Insets top="14" right="0" bottom="8" left="15"/>
        </padding>
    </Label>

    <ScrollPane VBox.vgrow="ALWAYS"
                minHeight="0.0"
                prefHeight="0.0"
                fitToWidth="true"
                style="-fx-background-color: #e8eef7;
                       -fx-background: #e8eef7;
                       -fx-border-color: transparent;">
        <Accordion fx:id="balancesAccordion"
                   style="-fx-background-color: #e8eef7;
                          -fx-border-color: transparent;
                          -fx-focus-color: transparent;
                          -fx-faint-focus-color: transparent;"/>
    </ScrollPane>

    <Label fx:id="emptyStateLabel"
           text="No outstanding balances."
           style="-fx-text-fill:#e8eef7;
                  -fx-font-size: 13;"
           wrapText="true">
        <padding>
            <Insets top="10" left="15"/>
        </padding>
    </Label>

</VBox>
