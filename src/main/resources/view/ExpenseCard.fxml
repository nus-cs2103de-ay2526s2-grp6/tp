<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<HBox xmlns:fx="http://javafx.com/fxml"
      spacing="10"
      style="-fx-background-color: #ffffff;
             -fx-background-radius: 10;
             -fx-border-radius: 10;
             -fx-effect: dropshadow(gaussian,
                         rgba(74,127,232,0.12), 8, 0, 0, 2);">
    <padding>
        <Insets top="12" right="14" bottom="12" left="14"/>
    </padding>
    <Label fx:id="indexLabel"
           style="-fx-text-fill: #9aaac8;
                  -fx-font-size: 12;"/>
    <VBox spacing="4">
        <Label fx:id="groupLabel"
               style="-fx-text-fill: #4a7fe8;
                      -fx-font-size: 11;
                      -fx-font-weight: bold;"/>
        <Label fx:id="expenseNameLabel"
               style="-fx-text-fill: #1a2a4a;
                      -fx-font-size: 14;
                      -fx-font-weight: bold;"/>
        <Label fx:id="amountLabel"
               style="-fx-text-fill: #2e7d32;
                      -fx-font-size: 13;
                      -fx-font-weight: bold;"/>
        <Label fx:id="payerLabel"
               style="-fx-text-fill: #4a5568;
                      -fx-font-size: 12;"/>
        <Label fx:id="participantsLabel"
               style="-fx-text-fill: #4a5568;
                      -fx-font-size: 12;"/>
        <Label fx:id="tagsLabel"
               style="-fx-text-fill: #6b7fa8;
                      -fx-font-size: 11;
                      -fx-font-style: italic;"/>
    </VBox>
</HBox>
