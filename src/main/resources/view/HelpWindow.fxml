<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            style="-fx-background-color: #e8eef7;
                   -fx-background: #e8eef7;">
    <VBox fx:id="helpContent"
          spacing="16"
          style="-fx-background-color: #e8eef7;">
        <padding>
            <Insets top="20" right="20"
                    bottom="20" left="20"/>
        </padding>

        <VBox spacing="6">
            <Label text="FairShare Commands"
                   style="-fx-font-size: 20;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1a2a4a;"/>
        </VBox>

        <VBox fx:id="helpSectionsContainer" spacing="16"/>
    </VBox>
</ScrollPane>
